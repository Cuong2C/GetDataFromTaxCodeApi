    "CaptchaUrl": "https://tracuunnt.gdt.gov.vn/tcnnt/captcha.png"
  },
  "ThongTinCongTyDotVn": {
    "BaseUrl": "https://thongtincongty.vn/ma-so-thue/",
    "nameLocator": "td.font-bold:has-text('Tên đơn vị') + td div",
    "addressLocator": "td.font-bold:has-text('Địa chỉ') + td div"
  },
